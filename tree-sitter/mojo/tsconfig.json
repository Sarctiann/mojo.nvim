{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "bundler",
    "allowJs": true,
    "checkJs": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["tree-sitter-cli/dsl"],
    "ignoreDeprecations": "6.0"
  },
  "include": ["grammar.js"]
}